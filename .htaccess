RewriteEngine On

# =========================
# MAIN PAGES
# =========================

RewriteRule ^about/?$ pages/About.html [L,NC]
RewriteRule ^services/?$ pages/Services.html [L,NC]
RewriteRule ^blog/?$ pages/Blog.html [L,NC]
RewriteRule ^courses/?$ pages/Courses.html [L,NC]
RewriteRule ^contact/?$ pages/Contact.html [L,NC]
RewriteRule ^privacy-policy/?$ pages/Privacy-Policy.html [L,NC]
RewriteRule ^terms-and-conditions/?$ pages/Terms-and-Conditions.html [L,NC]

# =========================
# SERVICE PAGES
# =========================

RewriteRule ^web-development/?$ services/web-development.html [L,NC]
RewriteRule ^mobile-app-development/?$ services/mobile-app-development.html [L,NC]
RewriteRule ^ecommerce-website-development/?$ services/ecommerce-website-development.html [L,NC]
RewriteRule ^seo-services/?$ services/seo-services.html [L,NC]
RewriteRule ^social-media-marketing/?$ services/social-media-marketing.html [L,NC]
RewriteRule ^digital-marketing/?$ services/digital-marketing.html [L,NC]
RewriteRule ^graphic-design/?$ services/graphic-design.html [L,NC]
RewriteRule ^ui-ux-design/?$ services/ui-ux-design.html [L,NC]
RewriteRule ^content-marketing/?$ services/content-marketing.html [L,NC]
RewriteRule ^branding/?$ services/branding.html [L,NC]
RewriteRule ^business-analysis/?$ services/business-analysis.html [L,NC]
RewriteRule ^digital-strategy/?$ services/digital-strategy.html [L,NC]
RewriteRule ^creative-design/?$ services/creative-design.html [L,NC]
RewriteRule ^content-design/?$ services/content-design.html [L,NC]
RewriteRule ^brand-consultancy/?$ services/brand-consultancy.html [L,NC]
RewriteRule ^aimarketing/?$ services/aimarketing.html [L,NC]

# =========================
# REMOVE .HTML FROM URLS
# =========================

RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ %1 [R=301,L]